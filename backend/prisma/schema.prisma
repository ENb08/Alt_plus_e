generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMINISTRATEUR
  DIRECTEUR
  ENSEIGNANT
  COMPTABLE
  ELEVE
  PARENT
  CONCEPTEUR
}

enum StatutPresence {
  PRESENT
  RETARD
  ABSENT
}

model ECOLE {
  id          String   @id @default(uuid())
  nom         String
  slug        String   @unique
  logo_url    String?
  adresse     String?
  telephone   String?
  email       String?
  date_creation DateTime @default(now())
  actif       Boolean  @default(true)

  utilisateurs    UTILISATEUR[]
  eleves          ELEVE[]
  enseignants     ENSEIGNANT[]
  parents         PARENT[]
  annee_scolaires ANNEE_SCOLAIRE[]
  classes         CLASSE[]
  cours           COURS[]
  seances         SEANCE[]
  cartes_qr       CARTE_QR[]
  presences       PRESENCE[]
  notes           NOTE[]
  bulletins       BULLETIN[]
  bulletin_lignes BULLETIN_LIGNE[]
  frais_scolaires FRAIS_SCOLAIRE[]
  paiements       PAIEMENT[]
  recus           RECU[]
  legons          LEGON[]
  lecon_fichiers  LEGON_FICHIER[]

  @@map("ecole")
}

model UTILISATEUR {
  id          String   @id @default(uuid())
  nom         String
  email       String
  mot_de_passe String
  role        Role
  date_creation DateTime @default(now())
  actif          Boolean  @default(true)
  version_session Int      @default(1)
  ecole_id       String
  ecole       ECOLE    @relation(fields: [ecole_id], references: [id])

  eleve      ELEVE?
  enseignant ENSEIGNANT?
  parent     PARENT?

  @@unique([email, ecole_id])
  @@index([ecole_id])
  @@map("utilisateur")
}

model ELEVE {
  id              String   @id @default(uuid())
  matricule       String
  postnom         String?
  sexe            String
  date_naissance  DateTime
  adresse         String?
  telephone_parent String?
  photo_url       String?
  classe_id       String
  ecole_id        String

  classe      CLASSE     @relation(fields: [classe_id], references: [id])
  ecole       ECOLE      @relation(fields: [ecole_id], references: [id])
  utilisateur UTILISATEUR @relation(fields: [id], references: [id])

  parents     ELEVE_PARENT[]
  cartes_qr   CARTE_QR[]
  presences   PRESENCE[]
  notes       NOTE[]
  bulletins   BULLETIN[]
  paiements   PAIEMENT[]

  @@unique([matricule, ecole_id])
  @@index([classe_id])
  @@index([ecole_id])
  @@map("eleve")
}

model ENSEIGNANT {
  id           String  @id @default(uuid())
  specialite   String?
  est_titulaire Boolean @default(false)
  ecole_id     String

  ecole       ECOLE      @relation(fields: [ecole_id], references: [id])
  utilisateur UTILISATEUR @relation(fields: [id], references: [id])

  cours        COURS[]
  classes      CLASSE[]    @relation("titulaire")
  legons       LEGON[]

  @@index([ecole_id])
  @@map("enseignant")
}

model PARENT {
  id        String  @id @default(uuid())
  telephone String?
  adresse   String?
  ecole_id  String

  ecole       ECOLE      @relation(fields: [ecole_id], references: [id])
  utilisateur UTILISATEUR @relation(fields: [id], references: [id])

  enfants ELEVE_PARENT[]

  @@index([ecole_id])
  @@map("parent")
}

model ELEVE_PARENT {
  id       String @id @default(uuid())
  eleve_id String
  parent_id String

  eleve  ELEVE  @relation(fields: [eleve_id], references: [id])
  parent PARENT @relation(fields: [parent_id], references: [id])

  @@unique([eleve_id, parent_id])
  @@index([eleve_id])
  @@index([parent_id])
  @@map("eleve_parent")
}

model ANNEE_SCOLAIRE {
  id        String   @id @default(uuid())
  libelle   String
  date_debut DateTime
  date_fin   DateTime
  active    Boolean  @default(false)
  ecole_id  String

  ecole   ECOLE    @relation(fields: [ecole_id], references: [id])
  classes CLASSE[]

  @@index([ecole_id])
  @@map("annee_scolaire")
}

model CLASSE {
  id              String  @id @default(uuid())
  nom_classe      String
  section         String
  niveau          String
  annee_scolaire_id String
  titulaire_id    String?
  ecole_id        String

  annee_scolaire ANNEE_SCOLAIRE @relation(fields: [annee_scolaire_id], references: [id])
  titulaire      ENSEIGNANT?    @relation("titulaire", fields: [titulaire_id], references: [id])
  ecole          ECOLE          @relation(fields: [ecole_id], references: [id])

  eleves  ELEVE[]
  cours   COURS[]
  frais   FRAIS_SCOLAIRE[]

  @@index([annee_scolaire_id])
  @@index([titulaire_id])
  @@index([ecole_id])
  @@map("classe")
}

model COURS {
  id           String  @id @default(uuid())
  intitule     String
  coefficient  Int
  classe_id    String
  enseignant_id String
  ecole_id     String

  classe     CLASSE     @relation(fields: [classe_id], references: [id])
  enseignant ENSEIGNANT @relation(fields: [enseignant_id], references: [id])
  ecole      ECOLE      @relation(fields: [ecole_id], references: [id])

  seances  SEANCE[]
  notes    NOTE[]
  legons   LEGON[]
  lignes   BULLETIN_LIGNE[]

  @@index([classe_id])
  @@index([enseignant_id])
  @@index([ecole_id])
  @@map("cours")
}

model SEANCE {
  id         String   @id @default(uuid())
  cours_id   String
  date       DateTime
  heure_debut DateTime
  heure_fin  DateTime
  ecole_id   String

  cours    COURS      @relation(fields: [cours_id], references: [id])
  ecole    ECOLE      @relation(fields: [ecole_id], references: [id])
  presences PRESENCE[]

  @@index([cours_id])
  @@index([ecole_id])
  @@map("seance")
}

model CARTE_QR {
  id           String   @id @default(uuid())
  code         String
  eleve_id     String
  date_creation DateTime @default(now())
  active       Boolean  @default(true)
  ecole_id     String

  eleve ELEVE @relation(fields: [eleve_id], references: [id])
  ecole ECOLE @relation(fields: [ecole_id], references: [id])

  @@unique([code, ecole_id])
  @@index([eleve_id])
  @@index([ecole_id])
  @@map("carte_qr")
}

model PRESENCE {
  id           String          @id @default(uuid())
  seance_id    String
  eleve_id     String
  date         DateTime
  heure_arrivee DateTime?
  statut       StatutPresence
  ecole_id     String

  seance SEANCE @relation(fields: [seance_id], references: [id])
  eleve  ELEVE  @relation(fields: [eleve_id], references: [id])
  ecole  ECOLE  @relation(fields: [ecole_id], references: [id])

  @@index([seance_id])
  @@index([eleve_id])
  @@index([ecole_id])
  @@map("presence")
}

model NOTE {
  id        String  @id @default(uuid())
  eleve_id  String
  cours_id  String
  cote      Float
  trimestre Int
  date      DateTime
  ecole_id  String

  eleve ELEVE @relation(fields: [eleve_id], references: [id])
  cours COURS @relation(fields: [cours_id], references: [id])
  ecole ECOLE @relation(fields: [ecole_id], references: [id])

  @@index([eleve_id])
  @@index([cours_id])
  @@index([ecole_id])
  @@map("note")
}

model BULLETIN {
  id             String   @id @default(uuid())
  eleve_id       String
  trimestre      Int
  date_generation DateTime @default(now())
  ecole_id       String

  eleve ELEVE           @relation(fields: [eleve_id], references: [id])
  ecole ECOLE           @relation(fields: [ecole_id], references: [id])
  lignes BULLETIN_LIGNE[]

  @@index([eleve_id])
  @@index([ecole_id])
  @@map("bulletin")
}

model BULLETIN_LIGNE {
  id         String  @id @default(uuid())
  bulletin_id String
  cours_id    String
  cote        Float
  coefficient Int
  ecole_id    String

  bulletin BULLETIN @relation(fields: [bulletin_id], references: [id])
  cours    COURS    @relation(fields: [cours_id], references: [id])
  ecole    ECOLE    @relation(fields: [ecole_id], references: [id])

  @@index([bulletin_id])
  @@index([cours_id])
  @@index([ecole_id])
  @@map("bulletin_ligne")
}

model FRAIS_SCOLAIRE {
  id              String  @id @default(uuid())
  libelle         String
  montant         Float
  classe_id       String
  annee_scolaire_id String
  ecole_id        String

  classe       CLASSE         @relation(fields: [classe_id], references: [id])
  ecole        ECOLE          @relation(fields: [ecole_id], references: [id])
  paiements    PAIEMENT[]

  @@index([classe_id])
  @@index([ecole_id])
  @@map("frais_scolaire")
}

model PAIEMENT {
  id             String   @id @default(uuid())
  eleve_id       String
  frais_scolaire_id String
  montant        Float
  date_paiement  DateTime
  mode_paiement  String
  reference      String?
  ecole_id       String

  eleve       ELEVE          @relation(fields: [eleve_id], references: [id])
  frais       FRAIS_SCOLAIRE @relation(fields: [frais_scolaire_id], references: [id])
  ecole       ECOLE          @relation(fields: [ecole_id], references: [id])
  recu        RECU?

  @@index([eleve_id])
  @@index([frais_scolaire_id])
  @@index([ecole_id])
  @@map("paiement")
}

model RECU {
  id             String   @id @default(uuid())
  paiement_id    String   @unique
  numero_recu    String
  date_generation DateTime @default(now())
  ecole_id       String

  paiement PAIEMENT @relation(fields: [paiement_id], references: [id])
  ecole    ECOLE    @relation(fields: [ecole_id], references: [id])

  @@unique([numero_recu, ecole_id])
  @@index([paiement_id])
  @@index([ecole_id])
  @@map("recu")
}

model LEGON {
  id           String   @id @default(uuid())
  titre        String
  objectifs    String?
  materiel     String?
  deroulement  String?
  evaluation   String?
  cours_id     String
  enseignant_id String
  date_creation DateTime @default(now())
  ecole_id     String

  cours      COURS          @relation(fields: [cours_id], references: [id])
  enseignant ENSEIGNANT     @relation(fields: [enseignant_id], references: [id])
  ecole      ECOLE          @relation(fields: [ecole_id], references: [id])
  fichiers   LEGON_FICHIER[]

  @@index([cours_id])
  @@index([enseignant_id])
  @@index([ecole_id])
  @@map("lecon")
}

model LEGON_FICHIER {
  id          String @id @default(uuid())
  legon_id    String
  nom_fichier String
  url_fichier String
  type        String
  ecole_id    String

  legon LEGON @relation(fields: [legon_id], references: [id])
  ecole ECOLE @relation(fields: [ecole_id], references: [id])

  @@index([legon_id])
  @@index([ecole_id])
  @@map("lecon_fichier")
}
